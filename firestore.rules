rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Quinielas: anyone authenticated can read all, but only write their own
    match /quinielas/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && (
        request.auth.uid == uid ||
        // Allow updating only points fields (for admin recalc)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points','exactCount','resultCount'])
      );
    }

    // Results: readable by all authenticated users, writable only by admin
    match /results/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email in [
        'YOUR_ADMIN_EMAIL@gmail.com'
      ];
    }
  }
}
